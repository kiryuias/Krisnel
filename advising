// ============================================================
// HTML: DASHBOARD SHELL
// ============================================================
function dashHTML(){
  const u=A.user,role=u.role;
  const tabs=role==='student'?[{id:'home',i:'🏠',l:'Overview'},{id:'grades',i:'📊',l:'Grade Evaluation'},{id:'regform',i:'📋',l:'Registration Form'},{id:'profile',i:'👤',l:'My Profile'}]
    :role==='admin'?[{id:'pending',i:'⏳',l:'Pending Approvals'},{id:'students',i:'🎓',l:'Student Management'},{id:'reports',i:'📈',l:'Reports'},{id:'special',i:'📂',l:'Special Cases'}]
    :[{id:'admins',i:'👥',l:'Admin Accounts'},{id:'allstu',i:'🎓',l:'All Students'},{id:'curriculum',i:'📚',l:'Curriculum Editor'},{id:'sreports',i:'📊',l:'Reports'}];
  const cur=tabs.find(t=>t.id===A.tab)||tabs[0];
  const rl={student:'Student',admin:'Administrator',superadmin:'Super Admin'};
  return`
<div class="app-layout">
  <div class="sidebar">
    <div class="sb-brand"><div class="sb-brand-name">Scholar<em>Gate</em></div><div class="sb-brand-tag">Advising System</div></div>
    <div class="sb-user">
      <div class="sb-name">${esc(u.name)}</div><div class="sb-role">${role}</div>
      <span class="sb-badge sb-${role}">${rl[role]}</span>
      ${role==='student'?`<div class="sb-info">${esc(u.si?.program||'')} · ${esc(u.si?.year_level||'')}</div>`:''}
    </div>
    <div class="sb-nav"><div class="sb-section">Menu</div>
      ${tabs.map(t=>`<button class="nav-btn${A.tab===t.id?' active':''}" data-a="nav" data-tab="${t.id}"><span class="nav-ico">${t.i}</span>${t.l}</button>`).join('')}
    </div>
    <div class="sb-foot"><button class="logout-btn" data-a="do-logout">🚪 Sign Out</button></div>
  </div>
  <div class="main-area">
    <div class="topbar">
      <div><div class="topbar-title">${cur.i} ${cur.l}</div><div class="topbar-sub">${today()}</div></div>
      ${role==='student'?`<span class="bdg ${tbdg(u.si?.student_type)}" style="font-size:12px;padding:4px 11px">${((u.si?.student_type||'')).replace(/^\w/,c=>c.toUpperCase())} Student</span>`:''}
    </div>
    <div class="page" id="content-area">${contentHTML()}</div>
  </div>
</div>
${A.modal?modalHTML():''}`;
}

function contentHTML(){
  const t=A.tab,role=A.user?.role;
  if(role==='student'){
    if(t==='home')    return stuHomeHTML();
    if(t==='grades')  return stuGradesHTML();
    if(t==='regform') return stuRegFormHTML();
    if(t==='profile') return stuProfileHTML();
    return stuHomeHTML();
  }
  if(role==='admin'){
    if(t==='pending')  return adminPendingHTML();
    if(t==='students') return adminStudentsHTML();
    if(t==='reports')  return reportsHTML();
    if(t==='special')  return adminSpecialHTML();
    return adminPendingHTML();
  }
  if(role==='superadmin'){
    if(t==='admins')     return superAdminsHTML();
    if(t==='allstu')     return adminStudentsHTML();
    if(t==='curriculum') return curriculumHTML();
    if(t==='sreports')   return reportsHTML();
    return superAdminsHTML();
  }
  return '';
}

// ============================================================
// STUDENT PAGES
// ============================================================
function stuHomeHTML(){
  const u=A.user,si=u.si||{};
  const prog=A.curriculum[si.program]||{};
  const all=Object.values(prog).flat();
  const totalU=all.reduce((a,s)=>a+s.units,0);
  const passed=Object.entries(si.grades||{}).filter(([,g])=>g>=75);
  const passedU=passed.reduce((a,[c])=>{const s=all.find(x=>x.code===c);return a+(s?.units||0);},0);
  const pct=totalU?Math.round(passedU/totalU*100):0;
  return`
<div class="g4" style="margin-bottom:16px">
  ${statHTML(si.program||'—','Program','sn','🎓')}
  ${statHTML(si.year_level||'—','Year Level','sg','📅')}
  ${statHTML(passed.length,'Passed Subjects','sv','✅')}
  ${statHTML(pct+'%','Curriculum Done','sr','📊')}
</div>
<div class="g2">
  <div class="card">
    <div class="card-head">📌 Academic Summary</div>
    ${[['Student ID',si.student_id||'Pending'],['Program',si.program],['Year Level',si.year_level],
      ['Semester',si.semester],['Student Type',si.student_type],
      ['Units Completed',passedU+' / '+totalU],['Account Status',u.status]].map(([k,v])=>kvHTML(k,v)).join('')}
  </div>
  <div class="card">
    <div class="card-head">ℹ️ Adviser Notes</div>
    ${alertHTML('al-i',si.student_type==='new'?'👋 Welcome! You are a new student. Visit the Registrar to confirm enrollment.'
      :si.student_type==='old'?'✅ Welcome back! Ensure grades are updated before enrolling.'
      :'📂 As a transferee, subjects will be manually evaluated by your adviser.')}
    <div style="font-size:13px;color:var(--muted);line-height:2">
      <div>📞 <b style="color:var(--ink)">${esc(si.contact||'N/A')}</b></div>
      <div>📍 <b style="color:var(--ink)">${esc(si.address||'N/A')}</b></div>
      <div>📅 Registered: <b style="color:var(--ink)">${esc(u.created_at)}</b></div>
    </div>
    ${si.manual_note?alertHTML('al-w','📋 Adviser: '+esc(si.manual_note)):''}
    ${si.manual_subjects?alertHTML('al-ok','✅ Accredited: '+esc(si.manual_subjects)):''}
  </div>
</div>`;}

function stuGradesHTML(){
  const u=A.user,si=u.si||{};
  if(si.student_type==='transferee') return`
  <div class="card"><div class="card-head">📊 Grade Evaluation</div>
    ${alertHTML('al-w','⚠ As a transferee, your records must be manually verified. Submit your official TOR to the Registrar\'s Office.')}
    ${si.manual_subjects?alertHTML('al-ok','✅ Accredited subjects: '+esc(si.manual_subjects)):''}
    ${si.manual_note?alertHTML('al-i','📋 Adviser\'s note: '+esc(si.manual_note)):''}
  </div>`;
  const period=`${si.year_level} - ${si.sem||si.semester}`;
  const prog=A.curriculum[si.program]||{};
  const curSubs=prog[period]||[];
  const evalR=A.evalResult;
  return`
<div class="card">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
    <div class="card-head" style="margin:0;border:0;padding:0">📊 Grades — ${esc(period)}</div>
    <div class="row no-print">
      <button class="btn btn-ghost btn-sm" data-a="save-grades">💾 Save Grades</button>
      <button class="btn btn-gold btn-sm" data-a="eval-grades">🔍 Evaluate</button>
    </div>
  </div>
  <p style="font-size:12px;color:var(--muted);margin-bottom:14px">Enter your grades. Passing mark: <b>75</b> and above.</p>
  ${curSubs.length===0?emptyHTML('📭','No subjects for "'+period+'". Update your Year Level & Semester in Profile.')
  :`<div class="grade-grid">${curSubs.map(s=>{
    const val=A.gradeInputs[s.code]??'';
    const cls=val!==''?(parseFloat(val)>=75?'gp':'gf'):'';
    return`<div class="gi"><label>${esc(s.title)}</label>
    <div class="sub">${esc(s.code)} · ${s.units}u${s.prereqs.length?' · Pre: '+esc(s.prereqs.join(', ')):''}
    </div><input type="number" min="0" max="100" placeholder="0 – 100" class="${cls}" data-grade="${esc(s.code)}" value="${esc(val)}"></div>`;
  }).join('')}</div>`}
</div>
${evalR?`
<div class="card"><div class="card-head">📋 Evaluation Result</div>
  ${evalR.passed.length?`<div class="ev-block evp"><div class="ev-head" style="color:var(--green)">✅ Passed (${evalR.passed.length})</div><div class="ev-tags">${evalR.passed.map(c=>`<span class="etag etp">${esc(c)}</span>`).join('')}</div></div>`:''}
  ${evalR.retake.length?`<div class="ev-block evf"><div class="ev-head" style="color:var(--red)">❌ For Retaking (${evalR.retake.length})</div><div class="ev-tags">${evalR.retake.map(s=>`<span class="etag etf">${esc(s.code)}: ${esc(s.title)}</span>`).join('')}</div></div>`:''}
  ${evalR.nextSubs.length?`<div class="ev-block evi"><div class="ev-head" style="color:var(--blue)">📌 Recommended for ${esc(evalR.nextPeriod)} (${evalR.nextSubs.length})</div><div class="ev-tags">${evalR.nextSubs.map(s=>`<span class="etag etr">${esc(s.code)}: ${esc(s.title)} (${s.units}u)</span>`).join('')}</div></div>`:''}
  ${evalR.nextSubs.length===0&&evalR.nextPeriod?alertHTML('al-w','⚠ Unmet prerequisites. Retake failed subjects before proceeding to '+esc(evalR.nextPeriod)+'.'):''}
</div>`:''}`;
}

function stuRegFormHTML(){
  const u=A.user,si=u.si||{};
  const period=`${si.year_level} - ${si.sem||si.semester}`;
  const prog=A.curriculum[si.program]||{};
  const passed=Object.entries(si.grades||{}).filter(([,g])=>g>=75).map(([c])=>c);
  const eligible=(prog[period]||[]).filter(s=>s.prereqs.every(p=>passed.includes(p)));
  const totalU=eligible.reduce((a,s)=>a+s.units,0);
  return`
<div class="row no-print" style="justify-content:flex-end;margin-bottom:12px">
  <button class="btn btn-gold btn-sm" data-a="print">🖨️ Print Form</button>
</div>
<div class="reg-box">
  <div class="reg-hdr">
    <h2>🎓 ScholarGate University</h2>
    <p>Academic Advising &amp; Enrollment Registration Form</p>
    <p style="font-size:11px;color:#aaa;margin-top:3px">A.Y. 2024–2025 · ${esc(period)}</p>
  </div>
  <div class="reg-meta">
    ${[['Student Name',u.name],['Student ID',si.student_id||'Pending'],
      ['Program',si.program],['Year Level',si.year_level],
      ['Semester',si.sem||si.semester],['Student Type',(si.student_type||'').toUpperCase()]]
      .map(([l,v])=>`<div class="rmi"><label>${l}</label><p>${esc(v||'—')}</p></div>`).join('')}
  </div>
  <div class="card-head" style="margin-bottom:12px">📚 Subjects for Enrollment</div>
  ${si.student_type==='transferee'
    ?alertHTML('al-w','⚠ Transferee: Subjects will be determined after manual evaluation by the Academic Adviser.')
    :`<div class="tbl-wrap"><table>
      <thead><tr><th>#</th><th>Code</th><th>Subject Title</th><th style="text-align:center">Units</th><th>Prerequisites</th><th>Status</th></tr></thead>
      <tbody>
        ${eligible.length===0?`<tr><td colspan="6" style="text-align:center;padding:18px;color:var(--muted)">No eligible subjects. Complete prerequisites first.</td></tr>`
          :eligible.map((s,i)=>`<tr><td>${i+1}</td><td><b>${esc(s.code)}</b></td><td>${esc(s.title)}</td><td style="text-align:center">${s.units}</td>
            <td style="font-size:12px;color:var(--muted)">${s.prereqs.join(', ')||'None'}</td>
            <td><span class="bdg ba">Eligible</span></td></tr>`).join('')}
        ${eligible.length?`<tr><tfoot><td colspan="3" style="padding:9px 12px;font-weight:700">TOTAL UNITS</td><td style="text-align:center;font-weight:700">${totalU}</td><td colspan="2"></td></tfoot></tr>`:''}
      </tbody>
