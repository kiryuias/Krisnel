}

async function approveStudent(id){
  const r=await api('approve_student',{id});
  if(r.error)toast(r.error,'error');
  else{A.students=A.students.map(s=>s.id==id?{...s,status:'approved'}:s);
    if(A.modal?.data?.id==id)A.modal.data.status='approved';
    toast('Student approved!');renderContent();}
}

async function rejectStudent(id){
  const r=await api('reject_student',{id});
  if(r.error)toast(r.error,'error');
  else{A.students=A.students.map(s=>s.id==id?{...s,status:'rejected'}:s);
    if(A.modal?.data?.id==id)A.modal.data.status='rejected';
    toast('Student rejected.','error');renderContent();}
}

async function saveSpecial(uid){
  const note=document.getElementById('sp-note-'+uid)?.value||'';
  const subj=document.getElementById('sp-subj-'+uid)?.value||'';
  A.specNotes[uid]=note;A.specSubjs[uid]=subj;
  const r=await api('save_special',{uid,note,subjects:subj});
  if(r.error)toast(r.error,'error');
  else{A.students=A.students.map(s=>s.id==uid?{...s,manual_note:note,manual_subjects:subj}:s);toast('Evaluation saved!');}
}

async function createAdmin(){
  const name=document.getElementById('na-name')?.value||'';
  const email=document.getElementById('na-email')?.value||'';
  const pass=document.getElementById('na-pass')?.value||'';
  const errEl=document.getElementById('na-err');
  const showErr=msg=>{if(errEl)errEl.innerHTML=`<div class="err-msg">⚠ ${esc(msg)}</div>`;};
  if(!name||!email||!pass){showErr('All fields are required.');return;}
  if(pass.length<6){showErr('Password must be at least 6 characters.');return;}
  const r=await api('create_admin',{name,email,password:pass});
  if(r.error)showErr(r.error);
  else{A.newAdm={name:'',email:'',pass:''};await refAdmins();toast('Admin account created!');renderContent();}
}

async function toggleAdmin(id){
  const r=await api('toggle_admin',{id});
  if(r.error)toast(r.error,'error');
  else{A.admins=A.admins.map(a=>a.id==id?{...a,status:r.status}:a);
    toast(`Admin ${r.status==='active'?'activated':'deactivated'}.`);renderContent();}
}

async function addPeriod(){
  const pn=document.getElementById('new-per')?.value.trim()||'';
  if(!pn){toast('Period name required.','error');return;}
  const r=await api('add_period',{program:A.currProg,period_name:pn});
  if(r.error)toast(r.error,'error');
  else{A.newPer='';await refCurr();A.currPeriod=pn;toast('Period added!');renderContent();}
}

async function addSubject(){
  const code=document.getElementById('ns-code')?.value||'';
  const title=document.getElementById('ns-title')?.value||'';
  const units=document.getElementById('ns-units')?.value||'3';
  const prereqs=document.getElementById('ns-prereqs')?.value||'';
  const errEl=document.getElementById('ns-err');
  const showErr=msg=>{if(errEl)errEl.innerHTML=`<div class="err-msg">⚠ ${esc(msg)}</div>`;};
  if(!code||!title){showErr('Subject code and title are required.');return;}
  const r=await api('add_subject',{program:A.currProg,period:A.currPeriod,code,title,units,prereqs});
  if(r.error)showErr(r.error);
  else{A.newSubj={code:'',title:'',units:'3',prereqs:''};await refCurr();toast('Subject added!');renderContent();}
}

async function removeSubject(id){
  if(!confirm('Remove this subject from the curriculum?'))return;
  const r=await api('remove_subject',{id});
  if(r.error)toast(r.error,'error');
  else{await refCurr();toast('Subject removed.');renderContent();}
}

// ============================================================
// EVENT DELEGATION
// ============================================================
document.body.addEventListener('click',function(e){
  const el=e.target.closest('[data-a]');if(!el)return;
  e.preventDefault();
  const a=el.dataset.a,id=el.dataset.id,tab=el.dataset.tab,uid=el.dataset.uid;
  switch(a){
    case 'go-reg':     A.page='register';render();break;
    case 'go-login':   A.page='login';render();break;
    case 'do-login':   doLogin();break;
    case 'do-register':doRegister();break;
    case 'do-logout':  doLogout();break;
    case 'nav':        A.tab=tab;render();break;
    case 'save-grades':saveGrades();break;
    case 'eval-grades':evalGrades();break;
    case 'save-profile':saveProfile();break;
    case 'approve':    approveStudent(id);break;
    case 'reject':     rejectStudent(id);break;
    case 'view-stu':   A.modal={type:'student',data:A.students.find(s=>s.id==id)};render();break;
    case 'close-modal':A.modal=null;render();break;
    case 'save-special':saveSpecial(uid);break;
    case 'create-admin':createAdmin();break;
    case 'toggle-admin':toggleAdmin(id);break;
    case 'add-period': addPeriod();break;
    case 'add-subject':addSubject();break;
    case 'rm-subject': removeSubject(id);break;
    case 'print':      window.print();break;
  }
});

document.body.addEventListener('change',function(e){
  const t=e.target;
  // Register transferee note
  if(t.id==='r-type'){const n=document.getElementById('r-transferee');if(n)n.style.display=t.value==='transferee'?'':'none';}
  // Student filters
  if(t.id==='stu-q')    {A.stuFilter.q=t.value;renderContent();}
  if(t.id==='stu-prog')  {A.stuFilter.prog=t.value;renderContent();}
  if(t.id==='stu-status'){A.stuFilter.status=t.value;renderContent();}
  if(t.id==='stu-type')  {A.stuFilter.type=t.value;renderContent();}
  // Curriculum selects
  if(t.id==='curr-prog'){A.currProg=t.value;const ps=Object.keys(A.curriculum[A.currProg]||{});A.currPeriod=ps[0]||'';renderContent();}
  if(t.id==='curr-period'){A.currPeriod=t.value;renderContent();}
});

document.body.addEventListener('input',function(e){
  const t=e.target;
  if(t.dataset.grade!==undefined) A.gradeInputs[t.dataset.grade]=t.value;
  // Persist new period input
  if(t.id==='new-per') A.newPer=t.value;
  // Persist new admin fields
  if(t.id==='na-name')  A.newAdm.name=t.value;
  if(t.id==='na-email') A.newAdm.email=t.value;
});

// Allow Enter key on login
document.body.addEventListener('keydown',function(e){
  if(e.key==='Enter'&&A.page==='login'){doLogin();}
});

// ============================================================
// INIT
// ============================================================
async function init(){
  if(<?=json_encode($loggedIn)?>){
    await loadData();
    if(!A.user)A.page='login';
  }
  render();
}

init();
</script>
