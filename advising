function db(){
    static $pdo=null;
    if(!$pdo){
        try{
            $pdo=new PDO("mysql:host=".DB_HOST.";dbname=".DB_NAME.";charset=utf8mb4",
                DB_USER,DB_PASS,[PDO::ATTR_ERRMODE=>PDO::ERRMODE_EXCEPTION,
                                  PDO::ATTR_DEFAULT_FETCH_MODE=>PDO::FETCH_ASSOC]);
        }catch(PDOException $e){
            header('Content-Type: application/json');
            echo json_encode(['error'=>'DB error: '.$e->getMessage()]);exit;
        }
    }
    return $pdo;
}
function resp($d){header('Content-Type: application/json');echo json_encode($d);exit;}
function need_auth(){if(!isset($_SESSION['uid']))resp(['error'=>'Not logged in']);}
function need_role($r){need_auth();if(!in_array($_SESSION['role'],(array)$r))resp(['error'=>'Access denied']);}

function get_user($id){
    $s=db()->prepare("SELECT * FROM users WHERE id=?");$s->execute([$id]);
    $u=$s->fetch();if(!$u)return null;
    unset($u['password']);
    if($u['role']==='student'){
        $si=db()->prepare("SELECT * FROM student_info WHERE user_id=?");$si->execute([$id]);
        $u['si']=$si->fetch()?:[];
        $gr=db()->prepare("SELECT subject_code,grade FROM grades WHERE user_id=?");$gr->execute([$id]);
        $u['si']['grades']=[];
        foreach($gr->fetchAll() as $g) $u['si']['grades'][$g['subject_code']]=(float)$g['grade'];
    }
    return $u;
}

// ── AJAX HANDLER ──────────────────────────────────────────────
if(isset($_POST['action'])||isset($_GET['action'])){
    $act=$_POST['action']??$_GET['action']??'';
    switch($act){

    case 'login':
        $s=db()->prepare("SELECT * FROM users WHERE email=?");$s->execute([$_POST['email']??'']);
        $u=$s->fetch();
        if(!$u||$u['password']!==($_POST['password']??'')) resp(['error'=>'Invalid email or password.']);
        if($u['role']==='student'&&$u['status']==='pending')  resp(['error'=>'Account pending admin approval.']);
        if($u['role']==='student'&&$u['status']==='rejected') resp(['error'=>'Account rejected. Contact admin.']);
        $_SESSION['uid']=$u['id'];$_SESSION['role']=$u['role'];
        resp(['ok'=>1,'user'=>get_user($u['id'])]);

    case 'logout':
        session_destroy();resp(['ok'=>1]);

    case 'me':
        need_auth();resp(['user'=>get_user($_SESSION['uid'])]);

    case 'register':
        $email=trim($_POST['email']??'');
        $c=db()->prepare("SELECT id FROM users WHERE email=?");$c->execute([$email]);
        if($c->fetch()) resp(['error'=>'Email already registered.']);
        db()->prepare("INSERT INTO users(name,email,password,role,status,created_at) VALUES(?,?,?,'student','pending',CURDATE())")
           ->execute([$_POST['name']??'',$email,$_POST['password']??'']);
        $uid=db()->lastInsertId();
        db()->prepare("INSERT INTO student_info(user_id,student_id,program,year_level,semester,student_type,contact,address,manual_note,manual_subjects) VALUES(?,?,?,?,?,?,?,?,'','')")
           ->execute([$uid,'',$_POST['program']??'BSCS',$_POST['year_level']??'1st Year',
                      $_POST['semester']??'1st Sem',$_POST['student_type']??'new',
                      $_POST['contact']??'',$_POST['address']??'']);
        resp(['ok'=>1]);

    case 'get_students':
        need_role(['admin','superadmin']);
        $rows=db()->query("SELECT u.*,si.id si_id,si.student_id,si.program,si.year_level,si.semester,si.student_type,si.contact,si.address,si.manual_note,si.manual_subjects FROM users u LEFT JOIN student_info si ON u.id=si.user_id WHERE u.role='student' ORDER BY u.created_at DESC")->fetchAll();
        foreach($rows as &$r){
            unset($r['password']);
            $g=db()->prepare("SELECT subject_code,grade FROM grades WHERE user_id=?");$g->execute([$r['id']]);
            $r['grades']=[];foreach($g->fetchAll() as $x) $r['grades'][$x['subject_code']]=(float)$x['grade'];
        }
        resp(['students'=>$rows]);

    case 'get_admins':
        need_role('superadmin');
        resp(['admins'=>db()->query("SELECT id,name,email,status,created_at FROM users WHERE role='admin' ORDER BY created_at DESC")->fetchAll()]);

    case 'get_curriculum':
        need_auth();
        $p=db()->query("SELECT * FROM curriculum_periods ORDER BY program,sort_order")->fetchAll();
        $s=db()->query("SELECT cs.id,cs.period_id,cs.subject_code,cs.subject_title,cs.units,GROUP_CONCAT(sp.prereq_code ORDER BY sp.id SEPARATOR ',') prereqs FROM curriculum_subjects cs LEFT JOIN subject_prerequisites sp ON cs.id=sp.subject_id GROUP BY cs.id ORDER BY cs.id")->fetchAll();
        resp(['periods'=>$p,'subjects'=>$s]);

    case 'save_grades':
        need_role('student');$uid=$_SESSION['uid'];
        $grades=json_decode($_POST['grades']??'{}',true)??[];
        foreach($grades as $code=>$grade){
            $c=db()->prepare("SELECT id FROM grades WHERE user_id=? AND subject_code=?");$c->execute([$uid,$code]);
            if($c->fetch()) db()->prepare("UPDATE grades SET grade=? WHERE user_id=? AND subject_code=?")->execute([$grade,$uid,$code]);
            else db()->prepare("INSERT INTO grades(user_id,subject_code,grade) VALUES(?,?,?)")->execute([$uid,$code,$grade]);
        }
        resp(['ok'=>1,'user'=>get_user($uid)]);

    case 'update_profile':
        need_role('student');$uid=$_SESSION['uid'];
        db()->prepare("UPDATE student_info SET program=?,year_level=?,semester=?,student_type=?,contact=?,address=? WHERE user_id=?")
           ->execute([$_POST['program'],$_POST['year_level'],$_POST['semester'],$_POST['student_type'],$_POST['contact'],$_POST['address'],$uid]);
        resp(['ok'=>1,'user'=>get_user($uid)]);

    case 'approve_student':
        need_role(['admin','superadmin']);
        db()->prepare("UPDATE users SET status='approved' WHERE id=? AND role='student'")->execute([$_POST['id']]);
        resp(['ok'=>1]);

    case 'reject_student':
        need_role(['admin','superadmin']);
        db()->prepare("UPDATE users SET status='rejected' WHERE id=? AND role='student'")->execute([$_POST['id']]);
        resp(['ok'=>1]);

    case 'save_special':
        need_role(['admin','superadmin']);
        db()->prepare("UPDATE student_info SET manual_note=?,manual_subjects=? WHERE user_id=?")
           ->execute([$_POST['note']??'',$_POST['subjects']??'',$_POST['uid']]);
        resp(['ok'=>1]);

    case 'create_admin':
        need_role('superadmin');$email=trim($_POST['email']??'');
        $c=db()->prepare("SELECT id FROM users WHERE email=?");$c->execute([$email]);
        if($c->fetch()) resp(['error'=>'Email already in use.']);
        db()->prepare("INSERT INTO users(name,email,password,role,status,created_at) VALUES(?,?,?,'admin','active',CURDATE())")
           ->execute([$_POST['name']??'',$email,$_POST['password']??'']);
        resp(['ok'=>1,'id'=>db()->lastInsertId()]);

    case 'toggle_admin':
        need_role('superadmin');
        $r=db()->prepare("SELECT status FROM users WHERE id=? AND role='admin'");$r->execute([$_POST['id']]);
        $row=$r->fetch();if(!$row)resp(['error'=>'Not found']);
        $ns=$row['status']==='active'?'inactive':'active';
        db()->prepare("UPDATE users SET status=? WHERE id=?")->execute([$ns,$_POST['id']]);
        resp(['ok'=>1,'status'=>$ns]);

    case 'add_period':
        need_role('superadmin');
        $pn=trim($_POST['period_name']??'');$pg=$_POST['program']??'';
        $c=db()->prepare("SELECT id FROM curriculum_periods WHERE program=? AND period_name=?");$c->execute([$pg,$pn]);
        if($c->fetch())resp(['error'=>'Period already exists.']);
        $m=db()->prepare("SELECT MAX(sort_order) m FROM curriculum_periods WHERE program=?");$m->execute([$pg]);
        $so=($m->fetch()['m']??0)+1;
        db()->prepare("INSERT INTO curriculum_periods(program,period_name,sort_order) VALUES(?,?,?)")->execute([$pg,$pn,$so]);
        resp(['ok'=>1,'id'=>db()->lastInsertId()]);

    case 'add_subject':
        need_role('superadmin');
        $code=strtoupper(trim($_POST['code']??''));$title=trim($_POST['title']??'');
        $pg=$_POST['program']??'';$per=$_POST['period']??'';$units=(int)($_POST['units']??3);
        $prereqs=array_filter(array_map('trim',explode(',',strtoupper($_POST['prereqs']??''))));
        $pid=db()->prepare("SELECT id FROM curriculum_periods WHERE program=? AND period_name=?");$pid->execute([$pg,$per]);
        $p=$pid->fetch();if(!$p)resp(['error'=>'Period not found.']);
        $ex=db()->prepare("SELECT id FROM curriculum_subjects WHERE period_id=? AND subject_code=?");$ex->execute([$p['id'],$code]);
        if($ex->fetch())resp(['error'=>'Code already exists in this period.']);
        db()->prepare("INSERT INTO curriculum_subjects(period_id,subject_code,subject_title,units) VALUES(?,?,?,?)")->execute([$p['id'],$code,$title,$units]);
        $sid=db()->lastInsertId();
        foreach($prereqs as $pr) if($pr) db()->prepare("INSERT INTO subject_prerequisites(subject_id,prereq_code) VALUES(?,?)")->execute([$sid,$pr]);
        resp(['ok'=>1]);

    case 'remove_subject':
        need_role('superadmin');
        db()->prepare("DELETE FROM curriculum_subjects WHERE id=?")->execute([$_POST['id']]);
        resp(['ok'=>1]);

    default: resp(['error'=>'Unknown action']);
    }
    exit;
}

