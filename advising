@media print{.sidebar,.topbar,.no-print{display:none!important}.main-area{padding:0!important}.page{padding:12px!important}}
</style>
</head>
<body>
<div id="app"><div class="loading">Loading ScholarGate…</div></div>
<script>
// ============================================================
// STATE
// ============================================================
const A={
  page:<?=json_encode($loggedIn?'dash':'login')?>,
  user:null,students:[],admins:[],curriculum:{},currPeriods:[],
  tab:'',modal:null,
  gradeInputs:{},evalResult:null,
  specNotes:{},specSubjs:{},
  stuFilter:{q:'',prog:'all',status:'all',type:'all'},
  currProg:'BSCS',currPeriod:'',
  newSubj:{code:'',title:'',units:'3',prereqs:''},
  newPer:'',
  newAdm:{name:'',email:'',pass:''},
};

// ============================================================
// UTILITIES
// ============================================================
function esc(s){return String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function toast(msg,type='success'){
  let el=document.getElementById('_toast');
  if(!el){el=document.createElement('div');el.id='_toast';document.body.appendChild(el);}
  el.className='toast toast-'+type;
  el.innerHTML=(type==='success'?'✅':type==='error'?'❌':'ℹ️')+' '+esc(msg);
  clearTimeout(el._t);
  el._t=setTimeout(()=>{if(el.parentNode)el.remove();},3200);
}
function bdg(s){return{pending:'bp',approved:'ba',rejected:'br',active:'ba',inactive:'br'}[s]||'';}
function tbdg(t){return{new:'bn',old:'bo',transferee:'bt'}[t]||'';}
function today(){return new Date().toLocaleDateString('en-PH',{weekday:'long',year:'numeric',month:'long',day:'numeric'});}
function statHTML(val,lbl,c,ico){return`<div class="stat ${c}"><div class="stat-val">${esc(val)}</div><div class="stat-lbl">${lbl}</div><div class="stat-ico">${ico}</div></div>`;}
function kvHTML(k,v){return`<div class="kv"><span class="kv-k">${k}</span><span class="kv-v">${esc(v||'—')}</span></div>`;}
function alertHTML(type,msg){return`<div class="alert ${type}">${msg}</div>`;}
function emptyHTML(ico,msg){return`<div class="empty"><div class="empty-ico">${ico}</div><p style="font-size:13px">${msg}</p></div>`;}

// ============================================================
// API
// ============================================================
async function api(action,data={}){
  const f=new FormData();f.append('action',action);
  for(const[k,v]of Object.entries(data))f.append(k,v);
  try{const r=await fetch(location.href,{method:'POST',body:f});return await r.json();}
  catch(e){return{error:'Network error'};}
}

// ============================================================
// CURRICULUM BUILDER
// ============================================================
function buildCurr(periods,subjects){
  const c={};
  for(const p of periods){if(!c[p.program])c[p.program]={};c[p.program][p.period_name]=[];}
  for(const s of subjects){
    const p=periods.find(x=>x.id==s.period_id);
    if(p&&c[p.program]&&c[p.program][p.period_name]!==undefined){
      c[p.program][p.period_name].push({id:s.id,code:s.subject_code,title:s.subject_title,
        units:parseInt(s.units),prereqs:s.prereqs?s.prereqs.split(',').filter(Boolean):[]});
    }
  }
  return c;
}

// ============================================================
// DATA LOADING
// ============================================================
async function loadData(){
  const[me,curr]=await Promise.all([api('me'),api('get_curriculum')]);
  if(me.user)A.user=me.user;
  if(curr.periods){A.currPeriods=curr.periods;A.curriculum=buildCurr(curr.periods,curr.subjects||[]);}
  if(A.user){
    A.gradeInputs={...(A.user.si?.grades||{})};
    if(!A.curriculum[A.currProg])A.currProg=Object.keys(A.curriculum)[0]||'BSCS';
    const ps=Object.keys(A.curriculum[A.currProg]||{});
    if(!A.currPeriod||!A.curriculum[A.currProg]?.[A.currPeriod])A.currPeriod=ps[0]||'';
    A.tab=A.user.role==='student'?'home':A.user.role==='admin'?'pending':'admins';
  }
  if(A.user?.role==='admin'||A.user?.role==='superadmin'){const s=await api('get_students');if(s.students)A.students=s.students;}
  if(A.user?.role==='superadmin'){const ad=await api('get_admins');if(ad.admins)A.admins=ad.admins;}
}
async function refStudents(){const s=await api('get_students');if(s.students)A.students=s.students;}
async function refAdmins(){const a=await api('get_admins');if(a.admins)A.admins=a.admins;}
async function refCurr(){
  const r=await api('get_curriculum');
  if(r.periods){A.currPeriods=r.periods;A.curriculum=buildCurr(r.periods,r.subjects||[]);
  const ps=Object.keys(A.curriculum[A.currProg]||{});
  if(!A.currPeriod||!A.curriculum[A.currProg]?.[A.currPeriod])A.currPeriod=ps[0]||'';}
}

// ============================================================
// RENDER
// ============================================================
function render(){
  const app=document.getElementById('app');
  if(A.page==='login')app.innerHTML=loginHTML();
  else if(A.page==='register')app.innerHTML=registerHTML();
  else if(A.page==='dash')app.innerHTML=dashHTML();
}
function renderContent(){const c=document.getElementById('content-area');if(c)c.innerHTML=contentHTML();else render();}

// ============================================================
// HTML: LOGIN
// ============================================================
function loginHTML(){return`
<div class="auth">
  <div class="auth-panel">
    <div class="brand">Scholar<em>Gate</em></div>
    <div class="brand-sub">Academic Advising System</div>
    <div class="auth-feats">
      ${['Smart grade evaluation & prerequisite checking','Automated registration form generation',
         '3-tier system: Student, Admin, Super Admin','Curriculum editor per degree program']
        .map(t=>`<div class="auth-feat"><div class="feat-dot"></div><div class="feat-txt">${t}</div></div>`).join('')}
