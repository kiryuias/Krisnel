<div style="min-height:100vh;background:var(--navy);display:flex;align-items:center;justify-content:center;padding:20px">
  <div style="background:#fff;border-radius:14px;padding:28px;width:100%;max-width:560px;max-height:95vh;overflow-y:auto">
