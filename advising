async function doLogin(){
  const email=document.getElementById('l-email')?.value||'';
  const pass=document.getElementById('l-pass')?.value||'';
  const r=await api('login',{email,password:pass});
  if(r.error){const el=document.getElementById('l-err');if(el)el.innerHTML=`<div class="err-msg">⚠ ${esc(r.error)}</div>`;}
  else if(r.user){
    A.user=r.user;A.gradeInputs={...(r.user.si?.grades||{})};
    A.page='dash';A.tab=r.user.role==='student'?'home':r.user.role==='admin'?'pending':'admins';
    await loadData();render();
  }
}

async function doRegister(){
  const g=id=>document.getElementById(id)?.value||'';
  const name=g('r-name'),email=g('r-email'),pass=g('r-pass'),pass2=g('r-pass2');
  const errEl=document.getElementById('r-err');
  const showErr=msg=>{if(errEl)errEl.innerHTML=`<div class="err-msg">⚠ ${esc(msg)}</div>`;};
  if(!name||!email||!pass||!g('r-contact')){showErr('Please fill all required fields.');return;}
  if(pass!==pass2){showErr('Passwords do not match.');return;}
  if(pass.length<6){showErr('Password must be at least 6 characters.');return;}
  const r=await api('register',{name,email,password:pass,program:g('r-prog'),
    year_level:g('r-year'),semester:g('r-sem'),student_type:g('r-type'),
    contact:g('r-contact'),address:g('r-addr')});
  if(r.error)showErr(r.error);
  else{A.page='login';render();toast('Registration submitted! Awaiting admin approval.','info');}
}

async function doLogout(){
  await api('logout');A.user=null;A.students=[];A.admins=[];
  A.page='login';A.tab='';render();
}

function evalGrades(){
  const si=A.user?.si||{},prog=A.curriculum[si.program]||{};
  const period=`${si.year_level} - ${si.sem||si.semester}`;
  const gmap={...(si.grades||{}),...Object.fromEntries(Object.entries(A.gradeInputs).filter(([,v])=>v!==''&&!isNaN(parseFloat(v))).map(([k,v])=>[k,parseFloat(v)]))};
  const passed=Object.entries(gmap).filter(([,g])=>g>=75).map(([c])=>c);
  const failed=Object.entries(gmap).filter(([,g])=>g<75).map(([c])=>c);
  const allS=Object.values(prog).flat();
  const perKeys=Object.keys(prog);
  const ci=perKeys.indexOf(period);
  const nextPeriod=perKeys[ci+1];
  const nextSubs=nextPeriod?(prog[nextPeriod]||[]).filter(s=>s.prereqs.every(p=>passed.includes(p))):[];
  const retake=allS.filter(s=>failed.includes(s.code));
  A.evalResult={passed,failed,retake,nextSubs,nextPeriod};
  renderContent();
}

async function saveGrades(){
  const grades={};
  Object.entries(A.gradeInputs).forEach(([k,v])=>{if(v!==''&&!isNaN(parseFloat(v)))grades[k]=parseFloat(v);});
  const r=await api('save_grades',{grades:JSON.stringify(grades)});
  if(r.error)toast(r.error,'error');
  else{if(r.user)A.user=r.user;A.gradeInputs={...(A.user.si?.grades||{})};A.evalResult=null;toast('Grades saved!');renderContent();}
}

